# === PostgreSQL Connection ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# === Google Sheets ===
GOOGLE_CREDS_FILE=credentials.json
SPREADSHEET_NAME=Your Spreadsheet Name Here

# === Dashboard Auth ===
# Secret used to sign session cookies — change this to a random string in production
COOKIE_SECRET=2345678987654346765434567887654

# === Meetings Sheet (shared across all MQL agents & campaigns) ===
# Get the Sheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
MEETING_SHEET_ID=1VXngoq-f1jlL13dJOXB8j2e2zR3lyRdARjoa0Qs1hnA

# === ETL Config ===
# CSV file path (default: csv_input/master_data.csv)
# CSV_FILE=csv_input/master_data.csv

# === AI Query Shell ===
# Choose one provider: gemini or claude
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# CLAUDE_API_KEY=your_claude_api_key_here
# CLAUDE_MODEL=claude-sonnet-4-6
